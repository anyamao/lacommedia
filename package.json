{
  "name": "lacommedia-monorepo",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "pnpm run --parallel dev",
    "dev:backend": "cd backend && source .venv/bin/activate && python manage.py runserver",
    "dev:frontend": "pnpm --filter frontend dev",
    "build": "pnpm --filter frontend build",
    "lint": "pnpm run --parallel lint",
    "lint:frontend": "pnpm --filter frontend lint",
    "format": "pnpm --filter frontend format",
    "type-check": "pnpm --filter frontend type-check",
    "clean": "pnpm run --parallel clean && rm -rf node_modules",
    "install:all": "pnpm install --filter frontend"
  },
  "packageManager": "pnpm@8.15.0"
}
